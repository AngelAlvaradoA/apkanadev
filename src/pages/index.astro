---
import '../styles/global.css';

const pageTitle = 'Estadisticas de uso de IA | Apkana Dev';
const pageDescription =
  'Landing en Astro sobre adopcion, uso y retos de la inteligencia artificial en equipos y empresas.';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

const adoptionStats = [
  {
    value: '88%',
    label: 'organizaciones reportan uso regular de IA en al menos una funcion',
    source: 'McKinsey, 2025',
  },
  {
    value: '11%',
    label: 'empresas del S&P 500 ya integran IA en procesos profundos',
    source: 'Yu et al., 2026',
  },
  {
    value: '12%',
    label: 'adopcion promedio de GenAI en trabajadores europeos',
    source: 'Henseke, 2026',
  },
];

const useCases = [
  'Investigacion y busqueda de informacion',
  'Redaccion, resumen y analisis de documentos',
  'Automatizacion de tareas repetitivas',
  'Soporte a decisiones con datos internos',
];

const stateCards = [
  {
    title: 'Cargando',
    body: 'Skeletons breves para metricas, fuentes o resultados que lleguen desde APIs.',
    className: 'border-info/30 bg-info/10',
  },
  {
    title: 'Vacio',
    body: 'Mensaje claro cuando todavia no hay mediciones o filtros aplicados.',
    className: 'border-warning/40 bg-warning/15',
  },
  {
    title: 'Error',
    body: 'Texto accionable, fuente del problema y una ruta de recuperacion visible.',
    className: 'border-error/30 bg-error/10',
  },
];

const sources = [
  {
    label: 'McKinsey State of AI 2025',
    href: 'https://www.mckinsey.com/capabilities/quantumblack/our-insights/the-state-of-ai',
  },
  {
    label: 'Stanford AI Index 2026',
    href: 'https://arxiv.org/abs/2606.15708',
  },
  {
    label: 'AI Adoption in S&P 500 Firms',
    href: 'https://arxiv.org/abs/2607.08920',
  },
  {
    label: 'Generative AI at Work in Europe',
    href: 'https://arxiv.org/abs/2604.18849',
  },
];
---

<html lang="es" data-theme="apkanadev">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-dvh">
    <a
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-neutral focus:px-4 focus:py-3 focus:text-neutral-content"
      href="#contenido"
    >
      Saltar al contenido
    </a>

    <header class="border-b border-slate-200 bg-white/90 backdrop-blur">
      <nav
        class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8"
        aria-label="Navegacion principal"
      >
        <a class="font-bold text-neutral" href="/pruebas-astro/" aria-label="Inicio Apkana IA">
          Apkana IA
        </a>
        <div class="hidden items-center gap-2 sm:flex">
          <a class="btn btn-ghost btn-sm" href="#estadisticas">Estadisticas</a>
          <a class="btn btn-ghost btn-sm" href="#fuentes">Fuentes</a>
        </div>
      </nav>
    </header>

    <main id="contenido">
      <section class="mx-auto grid min-h-[calc(86dvh-73px)] w-full max-w-7xl items-center gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-14">
        <div class="max-w-3xl">
          <p class="mb-4 inline-flex rounded-md bg-primary/10 px-3 py-2 text-sm font-bold text-primary">
            Inteligencia artificial en uso real
          </p>
          <h1 class="text-balance text-4xl font-black leading-tight text-neutral sm:text-5xl lg:text-6xl">
            La IA ya no es una promesa: se esta convirtiendo en habito operativo.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-700">
            Una vista breve para entender adopcion, casos de uso y el reto que
            viene despues: gobernar la IA sin frenar el aprendizaje de los equipos.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a class="btn btn-primary min-h-12" href="#estadisticas">Ver metricas</a>
            <a class="btn btn-outline min-h-12" href="#patrones">Explorar patrones</a>
          </div>
        </div>

        <aside class="rounded-lg border border-slate-200 bg-white p-4 shadow-xl" aria-label="Resumen de adopcion IA">
          <div class="stats stats-vertical w-full bg-transparent shadow-none">
            <div class="stat px-2">
              <div class="stat-title text-slate-600">Senal principal</div>
              <div class="stat-value text-primary">88%</div>
              <div class="stat-desc text-slate-600">uso regular de IA en al menos una funcion</div>
            </div>
            <div class="stat px-2">
              <div class="stat-title text-slate-600">Riesgo frecuente</div>
              <div class="stat-value text-secondary">Pilotos</div>
              <div class="stat-desc text-slate-600">muchos equipos aun no pasan a operacion medible</div>
            </div>
          </div>
        </aside>
      </section>

      <section id="estadisticas" class="border-y border-slate-200 bg-white py-14 sm:py-16">
        <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="max-w-3xl">
            <p class="text-sm font-bold uppercase text-primary">Metricas clave</p>
            <h2 class="mt-3 text-3xl font-black text-neutral sm:text-4xl">
              Tres numeros para leer el momento actual.
            </h2>
          </div>

          <div class="mt-8 grid gap-4 md:grid-cols-3">
            {
              adoptionStats.map((stat) => (
                <article class="card rounded-lg border border-slate-200 bg-white shadow-sm">
                  <div class="card-body gap-4">
                    <p class="text-5xl font-black text-neutral">{stat.value}</p>
                    <h3 class="text-lg font-bold leading-7 text-slate-800">{stat.label}</h3>
                    <p class="text-sm font-semibold text-slate-500">{stat.source}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="patrones" class="mx-auto grid w-full max-w-7xl gap-8 px-4 py-14 sm:px-6 sm:py-16 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
        <div>
          <p class="text-sm font-bold uppercase text-secondary">Uso cotidiano</p>
          <h2 class="mt-3 text-3xl font-black text-neutral sm:text-4xl">
            Donde empieza a crear valor.
          </h2>
          <p class="mt-5 text-base leading-7 text-slate-700">
            El patron mas sano no es reemplazar criterio humano, sino reducir friccion
            en tareas repetibles y medir calidad, tiempo y riesgo.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {
            useCases.map((item) => (
              <article class="rounded-lg border border-slate-200 bg-white/85 p-5 shadow-sm">
                <h3 class="text-lg font-bold text-neutral">{item}</h3>
                <p class="mt-3 text-sm leading-6 text-slate-600">
                  Requiere datos confiables, responsables claros y validacion humana.
                </p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="bg-neutral py-14 text-neutral-content sm:py-16">
        <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
            <div>
              <p class="text-sm font-bold uppercase text-accent">Estados de interfaz</p>
              <h2 class="mt-3 text-3xl font-black sm:text-4xl">
                Cada dato necesita una respuesta visible.
              </h2>
            </div>
            <div class="grid gap-4 md:grid-cols-3">
              {
                stateCards.map((card) => (
                  <article class={`rounded-lg border p-5 ${card.className}`}>
                    <h3 class="font-bold">{card.title}</h3>
                    <p class="mt-3 text-sm leading-6 text-neutral-content/80">{card.body}</p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section id="fuentes" class="mx-auto w-full max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-black text-neutral">Fuentes y criterio</h2>
          <p class="mt-3 max-w-3xl leading-7 text-slate-700">
            Los datos se usan como indicadores editoriales, no como auditoria sectorial.
            Antes de publicar una campana final conviene fijar pais, industria y fecha de corte.
          </p>
          <ul class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            {
              sources.map((source) => (
                <li>
                  <a class="link link-primary font-semibold" href={source.href} target="_blank" rel="noreferrer">
                    {source.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </section>
    </main>
  </body>
</html>
